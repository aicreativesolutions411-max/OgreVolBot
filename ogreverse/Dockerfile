FROM node:20-alpine

WORKDIR /app
ENV NODE_ENV=production
ENV OGREVERSE_HOST=0.0.0.0

COPY . .

EXPOSE 5178
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD ["node", "-e", "fetch(`http://127.0.0.1:${process.env.PORT || 5178}/healthz`).then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
CMD ["node", "server.mjs"]
