# ============================================================================
#  Lab harness config — SAFE DEFAULTS. Copy to .env for local runs.
#  This file contains NO secrets. Never put private keys, seed phrases,
#  Telegram bot tokens, or RPC/Jupiter API keys in here or anywhere in the repo.
# ============================================================================

# Global kill-switch. MUST stay true unless you are on an authorized devnet lab.
# Only the exact string "false" disables it; typos keep DRY_RUN on.
DRY_RUN=true

# Cluster gating. mainnet-beta is HARD-BLOCKED and can never broadcast.
SOLANA_CLUSTER=devnet          # devnet | localnet | testnet | mainnet-beta(blocked)

# Even on devnet, broadcasting a (harmless no-op) tx stays OFF unless this is true
# AND the live chain's genesis hash is verified to be devnet at runtime.
ALLOW_DEVNET_SEND=false

# Read-only Jupiter quotes. Mock is used unless this is true. Quotes never sign.
USE_REAL_JUPITER_QUOTES=false
JUPITER_QUOTE_BASE=https://quote-api.jup.ag/v6

# Public devnet RPC (no API key). NEVER point this at a mainnet endpoint — the
# harness verifies the genesis hash and refuses to send if it isn't devnet.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Admin allowlist — comma-separated Telegram chat IDs allowed to issue commands.
# Empty = deny everyone (deny-by-default).
ADMIN_CHAT_IDS=

# Safety ceilings.
RATE_LIMIT_PER_MIN=20
MAX_SLIPPAGE_BPS=100           # 1% default, hard ceiling 5%
MAX_AMOUNT_UI=5               # per-command amount ceiling (lab)

# Durable lab state.
DB_PATH=./swap-bot-lab.sqlite

# NOTE: there is intentionally no TELEGRAM_BOT_TOKEN here. The reference runs
# OFFLINE (handleUpdate driven by tests / the demo). Wiring a live getUpdates or
# webhook loop is an env-gated exercise for an authorized deployment review.
