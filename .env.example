# Optional: comma-separated Telegram numeric admin IDs.
# Public users can still use their own wallet/trading features.
TELEGRAM_ADMIN_USER_IDS=

# Optional defaults
DEFAULT_SLIPPAGE_BPS=400
SNIPER_DEFAULT_SLIPPAGE_BPS=400
JUPITER_SWAP_MAX_ATTEMPTS=3
PRIORITY_FEE_LAMPORTS=0

# Pump launch mint reserve. Pump launches fail safely before sending when the exact lowercase
# `pump` suffix reserve is empty; the background grinder refills it on the persistent disk.
LAUNCH_VANITY_ENABLED=true
LAUNCH_VANITY_SUFFIX=pump
LAUNCH_VANITY_CASE_INSENSITIVE=false
LAUNCH_VANITY_AUTOGRIND=true
LAUNCH_VANITY_POOL_TARGET=3
LAUNCH_VANITY_GRIND_WORKERS=1
# Optional dedicated persistent path. Render deployments with a /var/data disk use it automatically.
LAUNCH_VANITY_POOL_FILE=

# Ogre Tek / Perp Mode is hidden unless explicitly enabled.
OGRE_TEK_ENABLED=false
NEXT_PUBLIC_ENABLE_OGRE_TEK=false
OGRE_TEK_DEMO_MODE=true
OGRE_TEK_PROVIDER=mock
OGRE_TEK_MAX_LEVERAGE=5
OGRE_TEK_MAX_POSITION_SIZE=10000
OGRE_TEK_DAILY_LOSS_LIMIT=500
OGRE_TEK_ALLOWED_MARKETS=SOL-PERP,BTC-PERP,ETH-PERP
OGRE_TEK_EMERGENCY_DISABLED=false
OGRE_TEK_STALE_MARKET_MS=60000
OGRE_TEK_STALE_ACCOUNT_MS=60000

# Ogre Agent free provider router
# Add any of these optional keys in Render. Ogre Agent tries Groq, then Gemini, then OpenRouter, then OpenAI fallback.
GROQ_API_KEY=
OGRE_AGENT_GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
OGRE_AGENT_GEMINI_MODEL=gemini-2.5-flash-lite
OPENROUTER_API_KEY=
OGRE_AGENT_OPENROUTER_MODEL=openrouter/free
OGRE_AGENT_SITE_URL=https://slimewire.org
OGRE_AGENT_PROVIDER_TIMEOUT_MS=2800
# Optional: enables Ogre Agent to scan recent X posts for mentioned Solana CAs.
X_BEARER_TOKEN=
# Set false if you want to prevent paid OpenAI fallback for Ogre Agent chat.
OGRE_AGENT_OPENAI_FALLBACK=true

# Optional Coin Social Kit email forwarding. Without these, the kit is still generated and its
# alias is reserved, but forwarding remains pending. Never expose these values in the browser.
SOCIAL_KIT_EMAIL_DOMAIN=slimewire.org
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# Paid NFT Collection Studio (server-only; never expose these in web/public).
# Use a Scenario custom/image-to-image model with a reference-image input; its schema is discovered at runtime.
# Keep false until provider billing and production pricing have been verified end to end.
NFT_STUDIO_ENABLED=false
SCENARIO_API_KEY=
SCENARIO_API_SECRET=
SCENARIO_NFT_MODEL_ID=
# Optional JSON defaults required by the chosen Scenario model, for example {"aspectRatio":"1:1"}.
SCENARIO_NFT_MODEL_DEFAULTS_JSON=
# Customer reserve pricing. Only successful image steps are consumed; unused SOL is refunded.
NFT_STUDIO_PREVIEW_USD_EACH=0.06
NFT_STUDIO_ITEM_USD_EACH=0.10
NFT_STUDIO_PLATFORM_FEE_BPS=1200
NFT_STUDIO_RESERVE_BUFFER_BPS=1000
