TELEGRAM_BOT_TOKEN=123456:replace_me
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=replace-with-helius-key
# Optional fastest path: your own validator/private RPC. Used before Helius when set.
SOLANA_VALIDATOR_RPC_URL=
HELIUS_WS_URL=
RPC_RPS_LIMIT=40
DAS_RPS_LIMIT=8
HELIUS_DAS_ENRICHMENT_ENABLED=true
HELIUS_DAS_CACHE_TTL_MS=900000
HELIUS_DAS_TIMEOUT_MS=1600
# PumpPortal realtime websocket (free): sub-second token creations + live trade
# ticks for the fresh feed, Ogre A.I. fresh mode, and native charts. On by default.
PUMPPORTAL_WS_ENABLED=true
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
# Optional instant dev-watch via Helius webhooks. Create ONE "enhanced" webhook in
# the Helius dashboard pointing at https://<your-host>/api/internal/helius-webhook
# with an auth header, then set all three values. Address list syncs automatically.
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
HELIUS_WEBHOOK_SECRET=
APP_SECRET=replace-with-a-long-random-secret-and-never-change-it-after-wallets-exist
DATA_DIR=./data
ALLOW_EPHEMERAL_STORAGE=false
AUTO_SEND_RECOVERY_KEY_FILE=true
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=OgreTradeBot
WEB_PORTAL_URL=https://www.slimewire.org
OGRE_API_BASE=https://app.slimewire.org
WEB_ALLOWED_ORIGIN=https://www.slimewire.org,https://slimewire.org,https://ogrevolbot.pages.dev,https://*.ogrevolbot.pages.dev
WEB_SESSION_TTL_HOURS=720
# SlimeCash Coinbase hosted onramp (optional). Create a Secret API key in CDP;
