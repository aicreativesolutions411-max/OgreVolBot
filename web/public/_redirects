# SlimeWire routing (Cloudflare Pages / any _redirects-aware proxy).
# gg is THE site now and IS index.html, so "/" already serves it. These map the old-app entry
# aliases onto the new app, archive the old terminal at /old (static, APIs off), and keep referral
# links working. NOTE: no /api/* rule here on purpose — the existing API proxy is left untouched.
/classic        /old.html              200
/old            /old.html              200
/old/*          /old.html              200
/reference      /old.html              200
/archive        /old.html              200
/r/*            /?ref=:splat           302
# X/t.co links created before the backend-host fix still point at www.slimewire.org/x/.... Forward them
# to the Node service that owns the private lookup and signed Trade Pad handoff instead of SPA-falling home.
/x/*            https://app.slimewire.org/x/:splat  302
# Dynamic generated-site and rewards slugs must resolve to their dedicated
# static shells on slimewire.org. The browser keeps the original pathname, so
# each shell can read the slug and fetch live data from the backend.
/ca/*           /coin-site.html        200
/coin/*         /coin-site.html        200
/rewards/*      /partner-rewards.html  200
/launch-coin    /#launch               302
/quick          /fun.html              200
/quick/*        /fun.html              200
# SlimeCash installable PWA lives in its own /cash/ folder (own manifest + service
# worker scope so it installs as a separate app). Assets under /cash/* are real
# files and serve directly — only the bare path needs the shell rewrite.
/cash           /cash/index.html       200
/terminal       /index.html            200
/terminal/*     /index.html            200
/portal         /index.html            200
/portal/*       /index.html            200
/connect        /index.html            200
/login          /index.html            200
/account/login  /index.html            200
