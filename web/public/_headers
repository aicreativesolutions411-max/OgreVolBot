# NOTE: this web service is served by the Node app (src/index.js), which sets the
# authoritative Cache-Control headers. This file mirrors that policy for any CDN/proxy
# that honors a _headers file. Keep the two in sync.

# Entry doc + per-build config are always fetched fresh.
/index.html
  Cache-Control: no-store
/config.js
  Cache-Control: no-store

# Downloadable PDFs are re-generated in place (same filename), so they MUST revalidate every fetch —
# otherwise a stale copy (e.g. an older, sparser guide layout) stays pinned in the browser for hours.
/SlimeWire-TG-Guide.pdf
  Cache-Control: no-cache, must-revalidate
/SlimeWire-User-Manual.pdf
  Cache-Control: no-cache, must-revalidate

# The service worker MUST be revalidated on every load. If it is cached, browsers stay pinned to
# an OLD worker (which then hijacks navigations like /Ogreverse into the wrong page) until the cache
# expires — sometimes hours. no-store guarantees the newest worker is always picked up immediately.
/sw.js
  Cache-Control: no-store
/manifest.json
  Cache-Control: no-cache

# app.js / styles.css / overrides get a fresh ?v=<buildId> each deploy, so cache hard.
/app.js
  Cache-Control: public, max-age=31536000, immutable
/styles.css
  Cache-Control: public, max-age=31536000, immutable
/slimewire-final-overrides.css
  Cache-Control: public, max-age=31536000, immutable

# Other scripts/styles: revalidate quietly instead of re-downloading every visit.
/tailwind.css
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
/perps.js
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# Images, video, fonts are content-addressed by name.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
